# .distignore — Asset Lending Manager
# Files and folders excluded from the WordPress.org SVN distribution.
# Read by: wp dist-archive, 10up/action-wordpress-plugin-deploy, and compatible deploy scripts.

# Version control
.git
.gitignore
.gitattributes
.githooks
.distignore

# Composer / PHP dev dependencies
vendor
composer.json
composer.lock
.composer-cache
.composer-home

# Test suite
tests
phpunit.xml
phpunit-integration.xml
.phpunit.result.cache

# Code quality tooling
phpcs.xml.dist

# Development and documentation (internal)
DEV
AGENTS.MD
CLAUDE.MD
SETUP
DOC
README.md
CHANGELOG.md
VERSION.txt

